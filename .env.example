# ── Mock mode ─────────────────────────────────────────────────────────────────
# Set to true to run entirely without Supabase.
# All data is in-memory. A new "live" brick appears every ~9 seconds.
# The VITE_SUPABASE_* vars are not required when VITE_USE_MOCK=true.
VITE_USE_MOCK=false

# ── Supabase (required when VITE_USE_MOCK=false) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_ORG_ID=00000000-0000-0000-0000-000000000001
VITE_WALL_ID=00000000-0000-0000-0000-000000000002
VITE_ORG_NAME=My Organization

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email of the Supabase user who can access /admin
VITE_ADMIN_EMAIL=admin@example.com

# ── Storage ───────────────────────────────────────────────────────────────────
# Supabase Storage bucket for wall asset uploads (stone textures etc.)
# Create via: supabase/migrations/005_storage_bucket.sql
# Defaults to 'wall-assets' if not set.
VITE_ASSETS_BUCKET=wall-assets
